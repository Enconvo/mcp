{
  "$schema": "https://enconvo.com/schemas/extension.json",
  "name": "mcp",
  "version": "0.0.227",
  "description": "Model Context Protocol (MCP) client with connection pooling, supporting stdio, HTTP, and SSE transports with OAuth authentication for executing MCP server tools.",
  "title": "MCP(Model Context Protocol)",
  "icon": "icon.png",
  "author": "Enconvo",
  "license": "MIT",
  "type": "module",
  "minAppVersion": "1.8.8",
  "categories": [
    "Productivity"
  ],
  "commands": [
    {
      "name": "mcp_tool",
      "title": "MCP Tool",
      "description": "Run MCP Tool",
      "icon": "icon.png",
      "commandType": "function_command",
      "mode": "no-view",
      "private": true,
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "showInCommandList": false,
      "preferences": [
        {
          "name": "scope",
          "description": "scope",
          "type": "array",
          "title": "Scope",
          "default": [],
          "visibility": "hidden"
        },
        {
          "name": "access_token",
          "description": "access_token",
          "type": "password",
          "title": "Access Token",
          "default": "",
          "visibility": "hidden"
        },
        {
          "name": "oauth_client_information",
          "description": "oauth_client_information",
          "type": "password",
          "title": "OAuth Client Information",
          "default": "",
          "visibility": "hidden"
        },
        {
          "name": "refresh_token",
          "description": "refresh_token",
          "type": "password",
          "title": "Refresh Token",
          "default": "",
          "visibility": "hidden"
        },
        {
          "name": "expiry_date",
          "description": "expiry_date",
          "type": "number",
          "title": "Expiry Date",
          "default": 0,
          "visibility": "hidden"
        },
        {
          "name": "token_type",
          "description": "token_type",
          "type": "textfield",
          "title": "Token Type",
          "default": "",
          "visibility": "hidden"
        }
      ]
    },
    {
      "name": "api_list_servers",
      "title": "List Servers",
      "description": "List all servers",
      "icon": "icon.png",
      "mode": "no-view",
      "commandType": "api",
      "private": true,
      "parameters": {
        "type": "object",
        "properties": {}
      },
      "showInCommandList": false
    }
  ],
  "dependencies": {
    "@enconvo/api": "link:../../enconvo.nodejs/enconvo_api",
    "@enconvo/mcp": "link:/Users/ysnows/Documents/Project/packages/@enconvo:mcp",
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^8.57.0",
    "prettier": "^2.8.8",
    "tsup": "^8.5.1",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "lint": "eslint src",
    "lint:fix": "npm run lint --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --list-different \"**/*.ts\"",
    "build": "enconvo dev",
    "dev": "enconvo dev --dev"
  }
}